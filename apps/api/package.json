{
  "name": "@copa/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "npm --workspace @copa/shared run build",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm --workspace @copa/shared run build",
    "test": "jest --runInBand",
    "start": "node -r dotenv/config dist/main.js",
    "start:dev": "ts-node -r dotenv/config -r tsconfig-paths/register src/main.ts"
  },
  "dependencies": {
    "@copa/shared": "0.1.0",
    "@google-cloud/vision": "^5.3.6",
    "@google/genai": "^2.3.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.0",
    "bcryptjs": "^3.0.2",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.4.2",
    "mongoose": "^9.6.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.0",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
