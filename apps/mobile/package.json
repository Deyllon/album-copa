{
  "name": "@copa/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "pretest": "npm --workspace @copa/shared run build",
    "test": "jest --runInBand",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "expo start",
    "android": "expo run:android",
    "android:apk:debug": "cd android && ./gradlew assembleDebug",
    "android:apk:debug:windows": "cd android && gradlew.bat assembleDebug",
    "android:apk:release": "cd android && ./gradlew assembleRelease",
    "android:apk:release:windows": "cd android && gradlew.bat assembleRelease",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@copa/shared": "0.1.0",
    "@react-native-async-storage/async-storage": "^1.20.1",
    "expo": "^54.0.0",
    "expo-camera": "^17.0.0",
    "expo-clipboard": "^55.0.13",
    "react": "19.1.4",
    "react-native": "^0.81.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.4",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.0",
    "react-test-renderer": "19.1.4",
    "typescript": "^5.8.3"
  }
}
